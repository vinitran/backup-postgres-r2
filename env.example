# Database
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=postgres

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
